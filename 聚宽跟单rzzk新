def buy_code(ContextInfo,code,order_vol):
    tick = ContextInfo.get_full_tick([code])
    lastPrice = tick[code]['lastPrice']
    detail = ContextInfo.get_instrument_detail(code)
    up_limit = detail['UpStopPrice']
    make_price=round(lastPrice*(1+A.limt_set/100),2)
    order_price=min(up_limit,make_price)
    if order_vol>=100:
        print(f'{code}下单卖出  价格：{order_price}  委托量:{order_vol}')
        passorder(23, 1101, A.acct, code, 11, order_price, order_vol, 2, ContextInfo)
        A.limit_dict[code]=up_limit


def sell_code(ContextInfo,code,order_vol):
    tick = ContextInfo.get_full_tick([code])
    lastPrice = tick[code]['lastPrice']
    detail = ContextInfo.get_instrument_detail(code)
    dt_limit = detail['DownStopPrice']
    make_price=round(lastPrice*(1-A.limt_set/100),2)
    order_price=max(dt_limit,make_price)
    if order_vol>0:
        print(f'{code}下单卖出  价格:{order_price}   委托量:{order_vol}')
        passorder(24, 1101, A.acct, code, 11, order_price, order_vol, 2, ContextInfo)
        A.limit_dict[code]=dt_limit 




